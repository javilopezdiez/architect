{
  "featureName": "Client",
  "logLevelSettings": {
    "files": [
      {
        "path": "~/.vmware/view-preferences",
        "key": "view.defaultLogLevel",
        "logLevelMapping": {
          "INFO": "'3'",
          "DEBUG": "'2'",
          "TRACE": "'1'",
          "VERBOSE": "'0'"
        }
      },
      {
        "path": [
          "~/.vmware/config",
          "/usr/lib/vmware/config",
          "/etc/vmware/config"
        ],
        "key": "loglevel.crtbora",
        "logLevelMapping": {
          "INFO": "0",
          "DEBUG": "9",
          "TRACE": "9",
          "VERBOSE": "9"
        }
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "vmware-horizon-client*"
      },
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "vmware-crtbora-*"
      },
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "vmware-mks-*"
      },
      {
        "srcfolder": "/tmp/vmware-root",
        "rule": "vmware-installer-*"
      }
    ]
  }
}