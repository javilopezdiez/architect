{
  "featureName": "Printer Redirection",
  "logLevelSettings": {
    "files": [
      {
        "path": [
          "~/.vmware/config",
          "/usr/lib/vmware/config",
          "/etc/vmware/config"
        ],
        "key": "printRedirection.logLevel",
        "logLevelMapping": {
          "INFO": "info",
          "DEBUG": "debug",
          "TRACE": "trace",
          "VERBOSE": "verbose"
        }
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "vmware-print-*"
      }
    ]
  }
}