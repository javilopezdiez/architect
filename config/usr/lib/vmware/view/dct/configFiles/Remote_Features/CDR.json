{
  "featureName": "Client Drive Redirection",
  "logLevelSettings": {
    "files": [
      {
        "path": [
          "~/.vmware/config",
          "/usr/lib/vmware/config",
          "/etc/vmware/config"
        ],
        "key": "ViewTsdr-Client.TsdrLogger.logLevel"
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "vmware-ViewTsdr*"
      }
    ]
  }
}