{
  "featureName": "Scanner Redirection",
  "logLevelSettings": {
    "files": [
      {
        "path": "/etc/vmware/ftplugins.conf",
        "key": "log level",
        "defaultValue": "1",
        "logLevelMapping": {
          "INFO": "1",
          "DEBUG": "4",
          "TRACE": "4",
          "VERBOSE": "4"
        }
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "ftnlses3hv-*"
      },
      {
        "srcfolder": "/tmp/vmware-root",
        "rule": "ftscanhvd-*"
      }
    ]
  }
}