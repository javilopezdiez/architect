{
  "featureName": "Smart Card Redirection",
  "logLevelSettings": {
    "envVariables": [
      {
        "variable": "SC_LOG_DETAIL",
        "logLevelMapping": {
          "INFO": "UNSET",
          "DEBUG": "1,*",
          "TRACE": "1,*",
          "VERBOSE": "1,*"
        }
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "vmware-scredir*"
      },
      {
        "srcfolder": "PCOIP_LOG_DIR",
        "rule": "pcoip_client_*"
      }
    ]
  }
}