{
  "featureName": "VDPService",
  "logLevelSettings": {
    "files": [
      {
        "path": [
          "~/.vmware/config",
          "/usr/lib/vmware/config",
          "/etc/vmware/config"
        ],
        "key": "vdpService.log.logLevel"
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "VMWARE_TMP_DIR",
        "rule": "vmware-vdpService*"
      }
    ]
  }
}